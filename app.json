{
  "expo": {
    "name": "Monsterdex Community",
    "slug": "monsterdex",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/monsterdex.png",
    "userInterfaceStyle": "light",
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "package": "com.pokedexcommunity.app",
      "versionCode": 1,
      "adaptiveIcon": {
        "backgroundColor": "#CC0000",
        "foregroundImage": "./assets/monsterdex.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "splash": {
      "image": "./assets/monsterdex.png",
      "resizeMode": "contain",
      "backgroundColor": "#CC0000"
    },
    "plugins": [
      "expo-router"
    ],
    "scheme": "pokedex-community",
    "extra": {
      "apiBaseUrl": "http://pokemon.kingretar.my.id/v1"
    }
  }
}
